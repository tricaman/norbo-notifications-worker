# ── Redis (shared with norbo-api and dit-ping) ────────────────────────────
REDIS_URL=redis://localhost:6379

# ── PostgreSQL (shared with norbo-api) ────────────────────────────────────
DATABASE_URL=postgresql://dit:dit@localhost:5432/dit

# ── Firebase Admin SDK ───────────────────────────────────────────────────
# https://console.firebase.google.com/project/_/settings/serviceaccounts
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── Worker ───────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=10
LOG_LEVEL=info
NODE_ENV=development

# ── Reminder schedule override (optional) ────────────────────────────────
# Comma-separated seconds. Leave empty to use defaults from schedule.ts.
# REMINDER_OVERRIDE_SHORT=
# REMINDER_OVERRIDE_MEDIUM=
# REMINDER_OVERRIDE_LONG=
